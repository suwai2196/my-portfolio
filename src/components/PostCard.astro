---
interface Props {
  post: {
    id: string;
    data: { title: string; description: string; date: Date; tags: string[] };
  };
  // First sentence of the post body, used as the list summary. Falls back to
  // the frontmatter description when not provided.
  excerpt?: string;
}
const { post, excerpt } = Astro.props;
const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group" data-reveal>
  <a href={`/blog/${post.id}`} class="block py-4 border-b border-line">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-medium group-hover:text-accent transition-colors">{post.data.title}</h3>
      <time class="shrink-0 text-sm text-muted" datetime={post.data.date.toISOString()}>{dateStr}</time>
    </div>
    <p class="mt-1 text-sm text-muted">{excerpt ?? post.data.description}</p>
    {
      post.data.tags.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-1.5">
          {post.data.tags.map((t) => (
            <span class="rounded bg-accent-soft px-1.5 py-0.5 text-xs text-accent">{t}</span>
          ))}
        </div>
      )
    }
  </a>
</article>
