---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}
const { title, description, date, tags } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8 border-b border-line pb-6" data-reveal>
      <a href="/blog" class="text-sm text-accent hover:underline">← All posts</a>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight">{title}</h1>
      <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-muted">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {tags.map((t) => <span class="rounded bg-accent-soft px-1.5 py-0.5 text-xs text-accent">{t}</span>)}
      </div>
    </header>

    <div class="prose prose-neutral max-w-none prose-a:text-accent prose-headings:tracking-tight" data-reveal>
      <slot />
    </div>
  </article>
</BaseLayout>
