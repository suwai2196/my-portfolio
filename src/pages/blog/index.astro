---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PostCard from '../../components/PostCard.astro';

// Hide drafts in production; show them while developing.
const posts = (await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog" description="Notes and writing on NLP and tooling.">
  <PageHeader title="Blog" intro="Notes, write-ups, and the occasional deep dive." />

  {
    posts.length === 0 ? (
      <p class="text-muted" data-reveal>
        No posts yet. Add a Markdown file under <code>src/content/blog/</code>.
      </p>
    ) : (
      <div data-reveal>
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    )
  }
</BaseLayout>
