---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

// Drop the PDF at public/cv.pdf and the "Download PDF" button serves it.
const education = [
  {
    period: '2026 – 2031 (exp.)',
    title: 'Ph.D. in Information Science and Technology',
    org: 'Vidyasirimedhi Institute of Science and Technology (VISTEC), Thailand',
    note: 'VISTEC Full Scholarship · Advisor: Assoc. Prof. Dr. Sarana Nutanong',
  },
  {
    period: '2019 – 2021',
    title: 'M.Eng. in Information Management',
    org: 'Asian Institute of Technology, Thailand',
    note: 'CGPA 3.83/4.0 · Thesis: An Ontology-based Tutoring Chatbot Framework for Primary School Students',
  },
  {
    period: '2012 – 2019',
    title: 'B.E. in Information Science and Technology',
    org: 'University of Technology (Yadanapon Cyber City), Myanmar',
    note: 'CGPA 4.93/5.0',
  },
];

const experience = [
  {
    period: '2023 – 2026',
    title: 'Lecturer, Computer Engineering',
    org: 'KOSEN-KMITL · Lat Krabang, Thailand',
    note: 'Taught Software Security, Software Engineering, Data Structures & Algorithms, and C/Python programming; designed curricula and hands-on labs, and supervised student projects.',
  },
  {
    period: '2023',
    title: 'Data Science Coordinator',
    org: 'ONOW Myanmar · Yangon (Hybrid)',
    note: 'Led a 3-person data team and coordinated the cross-border launch of Project Starburst — a business-insights platform — between Thailand and Myanmar.',
  },
  {
    period: '2022 – 2023',
    title: 'Analytic Engineer',
    org: 'ONOW Myanmar · Yangon (Hybrid)',
    note: "Drove the organization's data culture and built the Data Mesh Marketplace, a Power BI platform for discovering data sources and attributes.",
  },
  {
    period: '2021 – 2022',
    title: 'Part-time English Teacher · Business Development Executive',
    org: 'Pace Online English School · Yangon (Hybrid)',
    note: 'Taught 1-on-1 English classes across levels; researched partner education centers and managed collaboration plans across partner schools.',
  },
];

---

<BaseLayout title="CV" description="Curriculum vitae.">
  <div class="flex items-start justify-between gap-4" data-reveal>
    <PageHeader title="Curriculum Vitae" />
    <a
      href="/cv.pdf"
      download="Su-Wai-Myo-CV.pdf"
      class="mt-1 shrink-0 rounded-md border border-line px-3 py-1.5 text-sm text-accent transition-colors hover:bg-accent-soft"
    >
      Download PDF
    </a>
  </div>

  <section class="mb-10" data-reveal>
    <h2 class="mb-4 text-sm font-medium uppercase tracking-wider text-muted">Education</h2>
    <div class="space-y-5">
      {
        education.map((e) => (
          <div class="grid grid-cols-[8rem_1fr] gap-4">
            <span class="text-sm text-muted">{e.period}</span>
            <div>
              <p class="font-medium">{e.title}</p>
              <p class="text-sm text-muted">{e.org}</p>
              {e.note && <p class="mt-0.5 text-sm text-muted">{e.note}</p>}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mb-10" data-reveal>
    <h2 class="mb-4 text-sm font-medium uppercase tracking-wider text-muted">Experience</h2>
    <div class="space-y-5">
      {
        experience.map((e) => (
          <div class="grid grid-cols-[8rem_1fr] gap-4">
            <span class="text-sm text-muted">{e.period}</span>
            <div>
              <p class="font-medium">{e.title}</p>
              <p class="text-sm text-muted">{e.org}</p>
              {e.note && <p class="mt-0.5 text-sm text-muted">{e.note}</p>}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
