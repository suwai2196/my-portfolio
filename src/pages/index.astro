---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import PublicationCard from "../components/PublicationCard.astro";
import { site, skills } from "../config";

// Selected publications for the homepage highlight.
const selected = (await getCollection("publications"))
  .filter((p) => p.data.selected)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section
    class="flex flex-col-reverse items-start gap-8 sm:flex-row sm:items-center"
    data-reveal
  >
    <div class="flex-1">
      <p class="text-sm font-medium uppercase tracking-wider text-accent">
        {site.role}
      </p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">
        {site.name}
      </h1>
      <p class="mt-3 text-lg italic text-muted">{site.tagline}</p>
      <p class="mt-5 max-w-xl leading-relaxed text-muted">{site.bio}</p>
      <div class="mt-6">
        <SocialLinks />
      </div>
    </div>
    <img
      src="/profile.jpeg"
      alt={site.name}
      width="140"
      height="140"
      class="h-32 w-32 rounded-full border border-line object-cover object-[50%_28%] sm:h-36 sm:w-36"
    />
  </section>

  <!-- Skills -->
  <section class="mt-16" data-reveal>
    <h2 class="text-sm font-medium uppercase tracking-wider text-muted">
      Research interests
    </h2>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        skills.map((s) => (
          <li class="rounded-full border border-line px-3 py-1 text-sm">{s}</li>
        ))
      }
    </ul>
  </section>

  <!-- Selected publications -->
  {
    selected.length > 0 && (
      <section class="mt-16" data-reveal>
        <div class="flex items-baseline justify-between">
          <h2 class="text-sm font-medium uppercase tracking-wider text-muted">
            Selected work
          </h2>
          <a href="/publications" class="text-sm text-accent hover:underline">
            All publications →
          </a>
        </div>
        <div class="mt-5 space-y-6">
          {selected.map((p) => (
            <PublicationCard pub={p.data} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Contact -->
  <section id="contact" class="mt-16 scroll-mt-24" data-reveal>
    <h2 class="text-sm font-medium uppercase tracking-wider text-muted">
      Get in touch
    </h2>
    <p class="mt-4 text-muted">
      I'm happy to talk about research, collaboration, or interesting problems.
      The best way to reach me is by email at{" "}
      <a
        href={`mailto:${site.email}`}
        class="font-semibold text-accent hover:underline"
      >
        <code>{site.email}</code>
      </a>.
    </p>
  </section>
</BaseLayout>
